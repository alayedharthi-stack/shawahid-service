# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/shawahid_db

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_ROOT=./storage
# On Railway: set STORAGE_DIR=/app/storage and mount a Volume
STORAGE_DIR=

# ── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
OPENAI_EXPORT_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30

# ── Moyasar Payment Gateway ───────────────────────────────────────────────────
# Get from: https://dashboard.moyasar.com → API Keys
MOYASAR_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
MOYASAR_WEBHOOK_SECRET=
MOYASAR_API_BASE=https://api.moyasar.com/v1
SHAWAHID_LAUNCH_PRICE_HALALAH=2900
SHAWAHID_LAUNCH_PRICE_SAR=29

# ── Payment (fallback if Moyasar not configured) ───────────────────────────────
PAYMENT_LINK_TEMPLATE=https://payment-provider.com/pay?teacher_id={teacher_id}&amount=29
PAYMENT_PROVIDER=moyasar
PAYMENT_SUCCESS_SECRET=

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
# Set these in Railway → Variables to enable real WhatsApp messaging.
# Verify token: choose any secret string, set the same in Meta Webhook settings.
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0

# ── Service ───────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8010
PUBLIC_BASE_URL=
APP_ENV=development
PORT=8010
