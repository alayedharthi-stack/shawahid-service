# Database
DATABASE_URL=postgresql://user:password@localhost:5432/shawahid_db

# Storage
STORAGE_ROOT=./storage

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# AI Classification (OpenAI)
OPENAI_API_KEY=sk-...
# Classifier model — upgrade to gpt-4o or gpt-4o-large for higher accuracy
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
# Model used when building export summaries (future use)
OPENAI_EXPORT_MODEL=gpt-4o-mini
# Seconds before AI call times out and falls back to rule-based classification
OPENAI_TIMEOUT_SECONDS=30

# Payment Link Template
PAYMENT_LINK_TEMPLATE=https://paylink.example.com/teacher/{teacher_id}

# WhatsApp Outbound (stub in MVP - wire to Twilio/Meta/360dialog later)
WHATSAPP_SEND_URL=
WHATSAPP_API_TOKEN=

# Service base URL (used for building file links)
BASE_URL=http://localhost:8010

# Port
PORT=8010
